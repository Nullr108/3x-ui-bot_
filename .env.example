# ── Telegram ─────────────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF...                 # токен от @BotFather
ADMIN_IDS=111111111,222222222                # tg user_id админов через запятую

# ── 3x-ui панель ─────────────────────────────────────────
# ВАЖНО: XUI_HOST — базовый URL БЕЗ хвоста /panel (см. шпаргалку §1).
# Если у панели base-path (/abcXYZ/panel/), включи его в host: ...:2053/abcXYZ
XUI_HOST=https://panel.example.com:2053
XUI_USERNAME=admin
XUI_PASSWORD=your-password
XUI_TOKEN=                                   # опц. bearer-токен (тогда login() не нужен)
XUI_TLS_VERIFY=true                          # false для самоподписанного сертификата

# URL панели для админской WebApp-кнопки (должен быть https).
# Обычно = XUI_HOST + /panel/  (или с base-path)
XUI_PANEL_URL=https://panel.example.com:2053/panel/

# ── Подписка / ссылка ────────────────────────────────────
# Параметры subscription из Settings → Subscription панели.
# Итоговая ссылка: {SUB_BASE}/{sub_id}
# Пример SUB_BASE: https://panel.example.com:2096/sub
SUB_BASE=https://panel.example.com:2096/sub

# ── Оплата ───────────────────────────────────────────────
PAYMENT_URL=https://example.com/pay          # статическая ссылка на оплату 200 ₽
PRICE_RUB=200

# ── Промокод (возврат старых клиентов) ───────────────────
PROMO_CODE=COMEBACK                           # секретный код, который раздаёшь старым клиентам
PROMO_DAYS=7                                  # на сколько дней даёт ключ промокод

# Секретный код для друзей → безлимитный бессрочный ключ (поменяй на свой).
FRIENDS_CODE=lunnyy-kit-1987

# ── Тайминги (для прода — реальные; для теста можно уменьшить) ─
TRIAL_DAYS=1                                 # срок триала, дней
TRIAL_LIMIT_IP=2                             # лимит устройств на триале
PAID_DAYS=30                                 # срок платной подписки, дней
CHECK_TRAFFIC_AFTER_HOURS=4                  # через сколько часов проверить трафик
REMIND_BEFORE_END_HOURS=3                    # за сколько часов до конца триала напомнить
NOTIFY_BEFORE_PAID_END_DAYS=1               # за сколько дней до конца платной уведомить
SYNC_INTERVAL_MINUTES=60                     # как часто сверять БД бота с панелью (удалённые клиенты)

# ── Прочее ───────────────────────────────────────────────
DB_PATH=bot.db
